{
  "name": "mysafeplay-bridge",
  "version": "1.6.42-alpha.23",
  "description": "MySafePlay Bridge - Local Camera Service that bridges network cameras with cloud application",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node test/test-discovery.js",
    "build": "npm run build:all",
    "build:all": "npm run build:windows && npm run build:linux && npm run build:macos",
    "build:windows": "pkg . --targets node18-win-x64 --output dist/mysafeplay-bridge-windows.exe",
    "build:linux": "pkg . --targets node18-linux-x64 --output dist/mysafeplay-bridge-linux",
    "build:macos": "pkg . --targets node18-macos-x64 --output dist/mysafeplay-bridge-macos",
    "package:windows": "npm run build:windows && cd dist && zip -r mysafeplay-bridge-v1.6.42-alpha.23-windows.zip mysafeplay-bridge-windows.exe ../config ../public ../README.md"
  },
  "keywords": [
    "camera",
    "rtsp",
    "onvif",
    "streaming",
    "webrtc",
    "security",
    "bridge"
  ],
  "author": "MySafePlay Team",
  "license": "MIT",
  "pkg": {
    "scripts": [
      "server.js",
      "services/**/*.js",
      "utils/**/*.js"
    ],
    "assets": [
      "config/**/*",
      "public/**/*",
      "node_modules/ffmpeg-static/ffmpeg*"
    ],
    "targets": [
      "node18-win-x64",
      "node18-linux-x64",
      "node18-macos-x64"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "ffmpeg-static": "^5.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-onvif": "^0.1.7",
    "rtsp-ffmpeg": "^0.0.9",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "pkg": "^5.8.1"
  }
}
